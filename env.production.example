# ========================================
# Performance Dashboard 本番環境設定
# ========================================
# cp env.production.example .env && php artisan key:generate

# アプリケーション
APP_NAME="GLUG業績ダッシュボード"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Tokyo
APP_URL=https://your-domain.com

# ログ
LOG_CHANNEL=daily
LOG_LEVEL=error

# データベース（さくらインターネット）
DB_CONNECTION=mysql
DB_HOST=mysql000.db.sakura.ne.jp
DB_PORT=3306
DB_DATABASE=performance_dashboard
DB_USERNAME=your_username
DB_PASSWORD=your_password

# セッション・キャッシュ
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/auth/google/callback
GOOGLE_HOSTED_DOMAIN=glug.co.jp

# 管理者（初期シーダー用）
ADMIN_EMAIL=admin@glug.co.jp
